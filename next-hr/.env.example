# Supabase (server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (browser + JWT validation for dashboard API calls)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: public site URL for invitation links (defaults to VERCEL_URL or localhost)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Shared secret for n8n webhooks and optional dashboard API (header x-hr-api-secret)
# If set, same value can be exposed to the browser as NEXT_PUBLIC_HR_API_SECRET for client-side generate/invite.
HR_API_SECRET=
# NEXT_PUBLIC_HR_API_SECRET=
